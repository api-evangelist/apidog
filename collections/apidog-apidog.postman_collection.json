                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scope\": \"ALL\",\n  \"oasVersion\": \"3.0\",\n  \"exportFormat\": \"JSON\",\n  \"environmentIds\": [\n    \"<integer>\",\n    \"<integer>\"\n  ],\n  \"branchId\": \"<integer>\",\n  \"moduleId\": \"<integer>\",\n  \"endpointIds\": [\n    \"<integer>\",\n    \"<integer>\"\n  ],\n  \"tags\": [\n    \"<string>\",\n    \"<string>\"\n  ],\n  \"options\": {\n    \"includeApidogExtensionProperties\": \"<boolean>\",\n    \"includeFolderNamesAsTags\": \"<boolean>\"\n  }\n}",
