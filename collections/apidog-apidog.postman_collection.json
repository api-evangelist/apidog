  "item": [
    {
      "id": "903d43d5-03f8-4466-aafc-dd44184e446f",
      "name": "Import And Export",
      "description": {
        "content": "Import and export API specification data in OpenAPI, Swagger, and Postman Collection formats.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "8ee1d1de-0efc-4869-835a-10d37610bc70",
          "name": "Import OpenAPI Or Swagger Data",
          "request": {
            "name": "Import OpenAPI Or Swagger Data",
            "description": {
              "content": "Import API specification data in OpenAPI 3 or Swagger 2 format into the specified Apidog project. The specification can be provided as a JSON or YAML string, or fetched from a URL. Advanced options control target folder, branch, module, overwrite behavior, and whether unmatched resources are deleted.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v1",
                "projects",
                ":projectId",
                "import-openapi"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "locale",
                  "value": "<string>",
                  "description": "Locale for response messages, e.g. `en-US`."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<integer>",
                  "key": "projectId",
                  "description": "(Required) The unique identifier of the Apidog project."
                }
              ]
            },
            "header": [
              {
                "disabled": false,
                "description": "(Required) The Apidog API version. Required for all requests. Current supported version is `2024-03-28`. Apidog supports previous versions for at least three months after a newer version launches.",
                "key": "X-Apidog-Api-Version",
                "value": "<string>"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"input\": \"<string>\",\n  \"options\": {\n    \"targetEndpointFolderId\": \"<integer>\",\n    \"targetSchemaFolderId\": \"<integer>\",\n    \"endpointOverwriteBehavior\": \"<string>\",\n    \"schemaOverwriteBehavior\": \"<string>\",\n    \"deleteUnmatchedResources\": \"<boolean>\",\n    \"targetBranchId\": \"<integer>\",\n    \"moduleId\": \"<integer>\",\n    \"importServersAsEnvironments\": \"<boolean>\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
              "id": "6af01343-965b-4dd1-a8b7-4eefb02c2fa8",
              "name": "Import completed successfully.",
              "originalRequest": {
                "url": {
                  "path": [
                    "v1",
                    "projects",
                    ":projectId",
                    "import-openapi"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [
                    {
                      "key": "locale",
                      "value": "en-US"
                    }
                  ],
                  "variable": [
                    {
                      "disabled": false,
                      "type": "any",
                      "value": "<integer>",
                      "key": "projectId",
                      "description": "(Required) The unique identifier of the Apidog project."
                    }
                  ]
                },
                "header": [
                  {
                    "description": {
                      "content": "Added as a part of security scheme: bearer",
                      "type": "text/plain"
                    },
                    "key": "Authorization",
                    "value": "Bearer <token>"
                  },
                  {
                    "disabled": false,
                    "description": "(Required) The Apidog API version. Required for all requests. Current supported version is `2024-03-28`. Apidog supports previous versions for at least three months after a newer version launches.",
                    "key": "X-Apidog-Api-Version",
                    "value": "2024-03-28"
                  },
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"input\": \"openapi: 3.0.0\\ninfo:\\n  title: Example API\\n  version: 1.0.0\\npaths: {}\",\n  \"options\": {\n    \"endpointOverwriteBehavior\": \"AUTO_MERGE\",\n    \"importServersAsEnvironments\": true\n  }\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"endpoint\": {\n      \"created\": 5,\n      \"updated\": 0,\n      \"failed\": 0,\n      \"ignored\": 0\n    },\n    \"schema\": {\n      \"created\": 3,\n      \"updated\": 0,\n      \"failed\": 0,\n      \"ignored\": 0\n    }\n  }\n}",
